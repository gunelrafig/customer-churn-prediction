# Step 1: Official lightweight Python image
FROM python:3.11-slim

# Step 2: Set the inside working directory
WORKDIR /app

# Step 3: Copy only dependency configurations first to leverage caching
COPY requirements.txt .

# Step 4: Install your project dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Step 5: Copy the remaining application source code 
COPY . .

# Step 6: Expose the networking ports for both FastAPI (8000) and Streamlit (8501)
EXPOSE 8000 

# Step 7: Launch FastAPI in the background (&) and Streamlit in the foreground
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]

